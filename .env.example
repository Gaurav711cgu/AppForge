# ================================================
# APPFORGE — Environment Variables
# ================================================

# ── Provider (grok or openai) ──────────────────
LLM_PROVIDER=groq

# ── Grok / xAI (get key at console.x.ai) ───────
GROQ_API_KEY=gsk_...

# To use xAI Grok instead:
# LLM_PROVIDER=grok
# XAI_API_KEY=xai-...

# ── OpenAI (alternative) ────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── App ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
