# ================================================
# APPFORGE — Environment Variables
# ================================================

# ── Provider (grok or openai) ──────────────────
LLM_PROVIDER=grok

# ── Grok / xAI (get key at console.x.ai) ───────
XAI_API_KEY=xai-...

# ── OpenAI (alternative) ────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── App ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
